sequenceDiagram
    autonumber
    actor Cron as ⏰ Cron Job
    participant Detector as Event Detector
    participant DB as PostgreSQL
    participant Dispatcher as Event Dispatcher
    participant AntiSpam as Anti-Spam Guard
    participant S2 as System 2 Agent
    participant UML as User Modeling
    participant Tools as Tool Registry
    participant Zalo as Zalo OA API
    participant Tenant as 🧑 Tenant

    Cron->>Detector: 9:00 AM - trigger
    activate Detector
    
    Detector->>DB: SELECT overdue invoices
    DB-->>Detector: [invoice_id: 456, tenant_id: 123, days_overdue: 3]
    
    loop For each overdue invoice
        Detector->>Dispatcher: dispatch(BackgroundEvent)
        activate Dispatcher
        
        Dispatcher->>AntiSpam: can_send(tenant_id)?
        activate AntiSpam
        AntiSpam->>DB: Check recent auto_* logs
        DB-->>AntiSpam: count=0, last=null
        AntiSpam-->>Dispatcher: can_send=true
        deactivate AntiSpam
        
        Dispatcher->>UML: build_context(tenant_id, instruction)
        activate UML
        UML->>DB: Get profile
        UML->>DB: Get behavior summary
        UML->>DB: Search relevant memories
        DB-->>UML: Context data
        UML-->>Dispatcher: AgentContext
        deactivate UML
        
        Dispatcher->>Tools: get_for_intent(payment_reminder)
        Tools-->>Dispatcher: [send_zalo, get_invoice_detail]
        
        Dispatcher->>S2: run(ReActRequest)
        activate S2
        
        Note over S2: ReAct Loop
        
        S2->>S2: Thought: Need to check invoice + send message
        S2->>Tools: get_invoice_detail(tenant_id, month)
        Tools->>DB: Query invoice
        DB-->>Tools: Invoice data
        Tools-->>S2: {amount: 3.5M, due: 2026-06-05}
        
        S2->>S2: Thought: Generate personalized message
        S2->>S2: Use friendly tone (profile.tone_preference)
        
        S2->>Tools: send_zalo(tenant_id, message)
        Tools->>Zalo: POST /message
        Zalo-->>Tools: success
        Tools-->>S2: {sent: true}
        
        S2->>S2: Final Answer: Tin nhắn đã gửi
        S2-->>Dispatcher: ReActResponse
        deactivate S2
        
        Dispatcher->>DB: INSERT behavior_log (auto_invoice_overdue)
        Dispatcher-->>Detector: result
    end
    
    deactivate Dispatcher
    deactivate Detector
    
    Note over Tenant: 📱 Nhận được Zalo nhắc nhở
    Zalo->>Tenant: "Anh Minh ơi, tháng này..."
    Tenant->>Tenant: Đọc tin nhắn
