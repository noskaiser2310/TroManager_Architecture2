graph TB
    subgraph Client["Client Layer"]
        ZaloApp[Zalo App]
        SMSApp[SMS]
        WebApp[Web App]
    end
    
    subgraph Edge["Edge / Load Balancer"]
        LB[Nginx<br/>SSL Termination]
    end
    
    subgraph App["Application Servers"]
        API1[FastAPI Instance 1]
        API2[FastAPI Instance 2]
        API3[FastAPI Instance N]
    end
    
    subgraph Workers["Background Workers"]
        Worker1[Cron Worker 1]
        Worker2[Cron Worker 2]
    end
    
    subgraph Data["Data Layer"]
        PG_M[(PostgreSQL<br/>Primary)]
        PG_R[(PostgreSQL<br/>Read Replica)]
        Redis[(Redis<br/>Session Cache)]
    end
    
    subgraph External["External APIs"]
        Gemini[Google Gemini API]
        ZaloAPI[Zalo OA API]
        Embed[Embedding API<br/>nomic-embed]
    end
    
    ZaloApp -->|HTTPS| LB
    SMSApp -->|Webhook| LB
    WebApp -->|HTTPS| LB
    
    LB --> API1
    LB --> API2
    LB --> API3
    
    API1 --> PG_M
    API2 --> PG_M
    API3 --> PG_M
    
    API1 --> PG_R
    API2 --> PG_R
    API3 --> PG_R
    
    API1 --> Redis
    API2 --> Redis
    API3 --> Redis
    
    PG_M -.replication.-> PG_R
    
    Worker1 --> PG_M
    Worker2 --> PG_M
    Worker1 --> Redis
    
    API1 --> Gemini
    API1 --> ZaloAPI
    API1 --> Embed
    
    classDef lb fill:#ffcdd2,stroke:#c62828
    classDef api fill:#c8e6c9,stroke:#2e7d32
    classDef db fill:#ffe0b2,stroke:#e65100
    classDef ext fill:#cfd8dc,stroke:#263238
    classDef worker fill:#e1bee7,stroke:#4a148c
    
    class LB lb
    class API1,API2,API3 api
    class PG_M,PG_R,Redis db
    class Gemini,ZaloAPI,Embed ext
    class Worker1,Worker2 worker
