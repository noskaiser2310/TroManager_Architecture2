graph TB
    User([Người dùng<br/>Zalo/SMS/App]):::user
    Cron([Background Cron]):::cron
    
    subgraph Entry["Entry Point"]
        GW[Router Gateway]:::router
    end
    
    subgraph S1["System 1 - Fast Layer"]
        Cache[Semantic Cache<br/>PostgreSQL + pgvector]:::db
        RAG[Knowledge Base<br/>LlamaIndex]:::db
        Flash[Gemini 3.0 Flash<br/>bản flash]:::llm
    end
    
    subgraph S2["System 2 - Core ReAct Agent"]
        Context[Context Builder]:::sys2
        Loop[ReAct Loop<br/>max 4 iterations]:::sys2
        Guard[Guardrails<br/>Loop Breaker]:::guard
    end
    
    subgraph Tools["Dynamic Tool Registry"]
        DT[Decision Toolkit]:::tool
        KT[Knowledge Toolkit]:::tool
        AT[Automation Toolkit]:::tool
    end
    
    subgraph UML["User Modeling Layer"]
        UP[(user_profiles)]:::db
        BL[(behavior_logs)]:::db
        UE[(user_embeddings)]:::db
        SC[(semantic_cache)]:::db
    end
    
    subgraph Ext["External Services"]
        Zalo[Zalo OA API]:::ext
        SMS[SMS Gateway]:::ext
    end
    
    User -->|Chat| GW
    Cron -->|Event JSON| Loop
    
    GW -->|FAQ / Static| Cache
    GW -->|Cache miss| RAG
    GW -->|Tool/Reasoning| Loop
    GW -.->|Sensitive| Loop
    
    Cache --> Flash
    RAG --> Flash
    Flash -->|Low conf| Loop
    
    Loop --> Context
    Context --> UP
    Context --> BL
    Context --> UE
    
    Loop --> DT
    Loop --> KT
    Loop --> AT
    
    DT --> UP
    KT --> UP
    KT --> BL
    AT --> Zalo
    AT --> SMS
    AT --> BL
    AT --> SC
    
    Loop --> Guard
    
    classDef user fill:#e1f5ff,stroke:#01579b
    classDef cron fill:#fff9c4,stroke:#f57f17
    classDef router fill:#ffcdd2,stroke:#c62828
    classDef sys2 fill:#c8e6c9,stroke:#2e7d32
    classDef llm fill:#d1c4e9,stroke:#4527a0
    classDef db fill:#ffe0b2,stroke:#e65100
    classDef tool fill:#b2dfdb,stroke:#004d40
    classDef guard fill:#f8bbd0,stroke:#880e4f
    classDef ext fill:#cfd8dc,stroke:#263238
