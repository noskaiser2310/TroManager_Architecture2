# =====================================================================
# Environment Variables Template (TroManager)
# =====================================================================
# COPY file này thành `.env` và điền giá trị thật:
#   cp .env.example .env
# File `.env` đã được gitignore, an toàn để commit secrets local.
# =====================================================================

# =====================================================================
# 1. LLM API (Gemini 3.0 hoặc OpenAI-compatible)
# =====================================================================
# Lấy API key tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Nếu dùng OpenAI thay vì Gemini:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# =====================================================================
# 2. Database (PostgreSQL 16 + pgvector)
# =====================================================================
# Connection string dạng: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tromanager
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tromanager
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_POOL_SIZE=10

# =====================================================================
# 3. Zalo OA (Official Account)
# =====================================================================
# Tạo OA tại: https://oa.zalo.me/
# Lấy access token tại: https://developers.zalo.me/docs/api/official-account-api
ZALO_ACCESS_TOKEN=your-zalo-oa-access-token
ZALO_OA_ID=your-zalo-oa-id

# Webhook secret để verify HMAC-SHA256 signature (X-Zalo-Signature header)
# Nếu set: webhook sẽ reject requests không có/sai signature
# Nếu không set: webhook chấp nhận tất cả (chỉ dùng cho dev)
# Generate bằng: python -c "import secrets; print(secrets.token_hex(32))"
ZALO_WEBHOOK_SECRET=

# =====================================================================
# 3.5 Landlord contact (cho guardrails fallback message)
# =====================================================================
# Số điện thoại chủ trọ/manager hiển thị trong fallback message
# khi ReAct loop breaker triggered. Nếu không set, fallback sẽ dùng
# message mặc định không có SĐT.
# Format: số Việt Nam, bỏ ký tự đặc biệt (vd: 0901234567)
LANDLORD_PHONE=

# =====================================================================
# 4. SMS Provider (Twilio hoặc VNPT/eSMS)
# =====================================================================
# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Vietnamese providers (eSMS/VNPT) - uncomment nếu dùng
# ESMS_API_KEY=your-esms-api-key
# ESMS_SECRET=your-esms-secret
# ESMS_BRAND_NAME=TROHAIDANG

# =====================================================================
# 5. Application
# =====================================================================
# Mode: development | production
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# =====================================================================
# 6. Optional: LLM Config Path Override
# =====================================================================
# Nếu không set, sẽ tự tìm config/llm_config.local.yaml trước,
# fallback về config/llm_config.yaml
# LLM_CONFIG_PATH=config/llm_config.local.yaml

# =====================================================================
# 7. Optional: Test/Debug flags
# =====================================================================
# Set true để log LLM requests mà không gọi API thật (chỉ dùng cho dev)
# LLM_DRY_RUN=false
# Set true để bypass auth (chỉ dùng cho dev)
# DEV_BYPASS_AUTH=true
